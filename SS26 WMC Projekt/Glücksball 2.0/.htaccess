AddDefaultCharset UTF-8
AddCharset UTF-8 .html .htm .css .js .json .php .txt

Options -Indexes

<IfModule mod_mime.c>
  AddType "text/html; charset=UTF-8" .html .htm
  AddType "text/css; charset=UTF-8" .css
  AddType "application/javascript; charset=UTF-8" .js
  AddType "application/json; charset=UTF-8" .json
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^(datenbank_backup|Auftrag)/ - [F,L]
  RewriteRule ^data/password_reset_links\.txt$ - [F,L]
  RewriteRule ^.*\.(sql|sqlite|db|bak|env|ini|log)$ - [F,L]
</IfModule>
